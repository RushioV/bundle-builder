    }
    closeAllDropdowns() {
        this.dropdownToggles.forEach(toggle => {
            const content = toggle.nextElementSibling;
            toggle.setAttribute("aria-expanded", "false"), content.setAttribute("aria-hidden", "true"), content.classList.remove("expanded")
        })
    }
    initVideoControls() {
        document.querySelectorAll(".key-compounds__video").forEach(wrap => {
            const video = wrap.querySelector(".key-compounds__video-el"),
                playBtn = wrap.querySelector(".key-compounds__video-play");
            if (!video || !playBtn) return;
            const shouldAutoplay = video.hasAttribute("data-autoplay"),
                hidePlayButton = () => {
                    playBtn.style.display = "none"
                },
                showPlayButton = () => {
                    playBtn.style.display = ""
                },
                attachPlayHandler = () => {
                    playBtn.addEventListener("click", handlePlayClick)
                },
                detachPlayHandler = () => {
                    playBtn.removeEventListener("click", handlePlayClick)
                },
                handlePlayClick = () => {
                    startPlayback()
                },
                startPlayback = () => {
                    detachPlayHandler(), hidePlayButton();
                    try {
                        const playPromise = video.play();
                        playPromise && typeof playPromise.then == "function" && playPromise.catch(() => {
                            video.controls = !0, showPlayButton(), attachPlayHandler()
                        })
                    } catch {
                        video.controls = !0, showPlayButton(), attachPlayHandler()
                    }
                },
                resetToPausedState = shouldPlay => {
                    video.controls = !1, shouldPlay || video.pause(), shouldPlay ? hidePlayButton() : (showPlayButton(), attachPlayHandler())
                };
            video.addEventListener("play", () => {
                video.controls = !0, hidePlayButton()
            }), video.addEventListener("pause", () => {
                video.ended || video.muted && (video.controls = !1, showPlayButton(), attachPlayHandler())
            }), video.addEventListener("ended", () => {
