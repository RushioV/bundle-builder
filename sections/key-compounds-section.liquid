    handleResize() {
        window.innerWidth <= 990 ? this.openFirstItem() : this.closeAllDropdowns()
    }
    openFirstItem() {
        if (this.dropdownToggles.length > 0) {
            const firstToggle = this.dropdownToggles[0],
                firstContent = firstToggle.nextElementSibling;
            this.closeAllDropdowns(), firstToggle.setAttribute("aria-expanded", "true"), firstContent.setAttribute("aria-hidden", "false"), firstContent.classList.add("expanded")
        }
    }
}
document.addEventListener("DOMContentLoaded", () => {
    new KeyCompounds
}), document.addEventListener("shopify:section:load", event => {
    event.detail.sectionId.includes("key-compounds") && new KeyCompounds
});
