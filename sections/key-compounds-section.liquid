<div class="key-compounds key-compounds-rounded">
  <div class="key-compounds__container">
    <div class="key-compounds__media">
      <div class="key-compounds__media-wrapper">
        {% if section.settings.media_type == "image" %}
          <div class="key-compounds__image-wrapper">
            <img src="{{ section.settings.background_image | image_url: width: 1600 }}" width="" height="" loading="lazy" alt="Mānuka Honey" class="key-compounds__image" />
          </div>
        {% elsif section.settings.media_type == "video" %}
          <div class="key-compounds__video-wrapper">
            <video class="key-compounds__video" autoplay muted playsinline loop preload="metadata">
              <source src="{{ section.settings.video_url }}" type="video/mp4" />
            </video>
          </div>
        {% endif %}
      </div>
    </div>

    
    <div class="key-compounds__content">
      <h2 class="key-compounds__title">{{ section.settings.section_title }}</h2>
      
      <div class="key-compounds__list">
        {% for block in section.blocks %}
          <div class="key-compounds__item">
            <div class="key-compounds__item-desktop">
              <div class="key-compounds__item-header">
                <h3 class="key-compounds__item-title">{{ block.settings.compound_title }}</h3>
              </div>
              <div class="key-compounds__item-description">
                {{ block.settings.compound_description }}
              </div>
            </div>
            <div class="key-compounds__item-mobile">
              <button class="key-compounds__item-toggle" aria-expanded="false" aria-controls="compound-{{ block.id }}">
                <div class="key-compounds__item-toggle-content">
                  <h3 class="key-compounds__item-title">{{ block.settings.compound_title }}</h3>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="29" height="29" viewBox="0 0 29 29" fill="none">
