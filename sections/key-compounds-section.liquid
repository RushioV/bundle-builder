{% schema %}
  {
    "name": "Key Compounds Section",
    "settings": [
      {
        "type": "header",
        "content": "Key Compounds Settings"
      },
      {
        "type": "inline_richtext",
        "id": "section_title",
        "label": "Section Title",
        "default": "The key compounds that make Mānuka honey a superfood"
      },
      {
        "type": "select",
        "id": "media_type",
        "label": "Select Media Type",
        "default": "image",
        "options": [
          {
            "value": "image",
            "label": "Image"
          },
          {
            "value": "video",
            "label": "Video"
          }
        ]
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Image",
      },
      {
        "type": "url",
        "id": "video_url",
        "label": "Video",
        "info": "Enter the video URL if you selected video as the media type."
      }
    ],
    "blocks": [
      {
        "type": "key_compound",
        "name": "Key Compound Block",
        "settings": [
          {
            "type": "inline_richtext",
            "id": "compound_title",
            "label": "Compound Title",
            "default": "Methylglyoxal (MGO)"
          },
          {
            "type": "richtext",
            "id": "compound_description",
            "label": "Compound Description",
          },
        ]
      },
    ],
    "presets": [
      {
        "name": "Key Compounds Section",
        "category": "Custom Sections"
      }
    ]
  }
{% endschema %}

