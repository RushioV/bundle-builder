                    <line x1="11.3184" y1="11.3183" x2="17.6824" y2="17.6823" stroke="#2E2E24"></line>
                    <line x1="17.6817" y1="11.3184" x2="11.3177" y2="17.6824" stroke="#2E2E24"></line>
                  </g>
                  <defs>
                    <clipPath id="clip0_204_38777">
                      <rect width="29" height="29" fill="white"></rect>
                    </clipPath>
                  </defs>
                </svg>
              </button>

                      
              <div class="key-compounds__item-content" id="compound-compound_{{ block.id }}" aria-hidden="true">
                <div class="key-compounds__item-description">
                {{ block.settings.compound_description }}
                </div>
              </div>

            </div>
          </div>
              
        {% endfor %}
      </div>

    </div>
  </div>
</div>

<style>
  .key-compounds__container {
      max-width: 1380px;
      margin: 0 auto;
      display: flex;
      gap: 21px;
      padding:55px 0px;
  }

  .key-compounds__media {
      position: relative;
      width: 100%;
      max-width: 682px;
      display: flex;
  }

  .key-compounds__image-wrapper,
  .key-compounds__video-wrapper {
      position: relative;
      overflow: hidden;
      height: 100%;
  }

  .key-compounds__image {
      width: 100%;
      height: 100%;
      display: block;
      border-radius: 20px;
      object-fit:cover;
  }

  .key-compounds__video {
      position: relative;
      width: 100%;
      height: 100%;
  }

  .key-compounds__video video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
  }

  .key-compounds__video-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: none;
      border: none;
      cursor: pointer;
      transition: transform 0.3s ease;
      z-index: 2;
  }

  .key-compounds__video-play:hover {
      transform: translate(-50%, -50%) scale(1.1);
  }

  .key-compounds__video.playing .key-compounds__video-play {
      opacity: 0;
      pointer-events: none;
  }

  .key-compounds__content {
      width: 100%;
      max-width: 677px;
      outline: 1.5px solid #043085;
      padding: 113.5px 29px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 84px;
      background-color:#043085;
  }

  .key-compounds__title {
    font-size: 2.5rem;
      font-weight: 500;
      line-height: 42px;
      margin-bottom: 40px;
      color:#fff;
      margin-top:0px;
  }

  .key-compounds__description {
      font-size: 24px;
  }

  .key-compounds__description p {
      margin: 0 0 16px 0;
      color:#fff;
  }

  .key-compounds__description p:last-child {
      margin-bottom: 0;
  }

  .key-compounds__list {
      display: flex;
      gap: 39px;
      row-gap: 46px;
      flex-wrap: wrap;
  }

  .key-compounds__item {
      transition: all .3s ease;
      width: calc(50% - 19.5px);
  }

  .key-compounds__item-desktop {
      display: flex;
      flex-direction: column;
  }

  .key-compounds__item-mobile {
      display: none;
  }

  .key-compounds__item-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 18px;
      border-bottom: 1px solid #fff;
      margin-bottom: 11px;
  }

  .key-compounds__item-title {
      font-family: 'Moret';
      font-weight: 400;
      font-size: 26px;
      line-height: 31px;
      margin: 0;
      color: #fff;
  }

  .key-compounds__item-description {
      line-height: 17px;
      max-width: 252px;
  }

  .key-compounds__item-description p {
      margin: 0 0 12px 0;
      color:#fff;
      font-size:14px;
      line-height:normal;
  }

  .key-compounds__item-description p:last-child {
      margin-bottom: 0;
  }

  .key-compounds__item-toggle {
      width: 100%;
      background: none;
      border: none;
      border-bottom: 1px solid #fff;
      padding: 0;
      text-align: left;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 9px;
  }

  .key-compounds__item-toggle svg path {
    fill:#fff;
  }
  .key-compounds__item-toggle-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex: 1;
      margin-right: 16px;
  }

  .key-compounds__item-chevron {
      color: #2E2E24;
      transition: transform 0.3s ease;
      flex-shrink: 0;
  }

  .key-compounds__item-toggle[aria-expanded="true"] .key-compounds__item-chevron {
      transform: rotate(180deg);
  }

  .key-compounds__item-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding-top 0.3s ease;
      padding-top: 0;
  }

  .key-compounds__item-content.expanded {
      max-height: 500px;
      padding-top: 15px;
      padding-bottom: 15px;
  }

  .key-compounds-rounded .key-compounds__media,
  .key-compounds-rounded .key-compounds__content {
      border-radius: 20px;
      overflow: hidden;
  }

  @media (max-width: 1200px) {
      .key-compounds__container {
            padding: 25px 0px;
      }
      .key-compounds__content {
          padding-top: 45px;
          padding-bottom: 45px;
          gap: 20px;
      }

      .key-compounds__title {
          margin-bottom: 20px;
      }
  }

  @media (max-width: 990px) {
      .key-compounds__item-desktop {
          display: none;
      }

      .key-compounds__item-mobile {
          display: block;
      }

      .key-compounds__list {
          flex-direction: column;
          gap: 20px;
      }

      .key-compounds__item {
          width: 100%;
      }

      .key-compounds__title {
          font-size: 28px;
          line-height: 100%;
      }
  }

  @media (max-width: 768px) {
      .key-compounds {
          padding: var(--padding-top-mobile, 25px) 15px var(--padding-bottom-mobile, 25px);
      }

      .key-compounds__container {
          flex-direction: column;
          gap: 11px;
      }

      .key-compounds__media {
          max-width: none;
      }

      .key-compounds__image-wrapper,
      .key-compounds__video-wrapper {
          width: 100%;
          min-height: 405px;
      }

      .key-compounds__content {
          max-width: none;
          padding: 42px 20px 20px;
          outline: 1px solid var(--border-color, #2E2E24);
          gap: 27px;
      }

      .key-compounds__title {
          font-size: 24px;
          line-height: 26px;
      }

      .key-compounds__item-title {
          font-size: 18px;
          line-height: 22px;
      }

      .key-compounds__list {
          gap: 10px;
      }

      .key-compounds__item-description {
          font-size: 12px;
          line-height: 14px;
          max-width: none;
      }
  }
</style>

<script>
  class KeyCompounds {
    constructor() {
        this.section = document.querySelector(".key-compounds"), this.section && (this.dropdownToggles = this.section.querySelectorAll(".key-compounds__item-toggle"), this.init())
    }
    init() {
        this.initDropdowns(), this.initVideoControls(), this.handleResize(), window.addEventListener("resize", this.handleResize.bind(this)), this.initDefaultState()
    }
    initDefaultState() {
        window.innerWidth <= 990 && this.openFirstItem()
    }
    initDropdowns() {
        this.dropdownToggles.forEach(toggle => {
            toggle.addEventListener("click", this.handleDropdownToggle.bind(this)), toggle.addEventListener("keydown", e => {
                (e.key === "Enter" || e.key === " ") && (e.preventDefault(), this.handleDropdownToggle(e))
            })
        })
    }
    handleDropdownToggle(event) {
        const toggle = event.currentTarget,
            content = toggle.nextElementSibling,
            isExpanded = toggle.getAttribute("aria-expanded") === "true";
