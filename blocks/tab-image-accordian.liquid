                  </g>
                  <path d="M13.9431 19.499V15.0741H9.99609V13.9045H13.9431V9.49902H15.0491V13.9045H18.9961V15.0741H15.0491V19.499H13.9431Z" fill="#2E2E24"></path>
                  <defs>
                  <clipPath id="clip0_204_38896">
                  <rect width="29" height="29" fill="white"></rect>
                  </clipPath>
                  </defs>
                </svg>
              </span>
            </button>
            <div class="ctm-mobile-accordion-content-{{ ctm_gen_id }}">
              <div class="ctm-mobile-accordion-body-{{ ctm_gen_id }}">
                <div class="ctm-content-wrapper-{{ ctm_gen_id }} {% if block.settings.image_position == 'right' %}image-right{% endif %}">
                  <div class="ctm-image-container-{{ ctm_gen_id }}">
                    {% if block.settings[tab_image_key] %}
                      <img
                        src="{{ block.settings[tab_image_key] | image_url: width: 800 }}"
                        alt="{{ block.settings[tab_image_key].alt | escape }}"
                        loading="lazy"
                        width="{{ block.settings[tab_image_key].width }}"
                        height="{{ block.settings[tab_image_key].height }}"
                      >
                    {% else %}
                      <div class="ctm-image-placeholder-{{ ctm_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="ctm-text-container-{{ ctm_gen_id }}">
                    {% if block.settings[tab_content_title_key] != blank %}
                      <h3 class="ctm-tab-title-{{ ctm_gen_id }}">{{ block.settings[tab_content_title_key] }}</h3>
                    {% endif %}

                    {% if block.settings[tab_description_key] != blank %}
                      <div class="ctm-tab-description-{{ ctm_gen_id }}">
                        {{ block.settings[tab_description_key] }}
                      </div>
                    {% endif %}

                    <div class="ctm-accordion-{{ ctm_gen_id }}">
                      {% for j in (1..3) %}
                        {% assign accordion_enabled_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_enabled' %}
                        {% assign accordion_title_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_title' %}
                        {% assign accordion_content_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_content' %}
                        
                        {% if block.settings[accordion_enabled_key] and block.settings[accordion_title_key] != blank %}
                          <div class="ctm-accordion-item-{{ ctm_gen_id }}">
                            <button
                              class="ctm-accordion-header-{{ ctm_gen_id }}"
                              aria-expanded="false"
                              data-accordion="tab-{{ i }}-acc-{{ j }}"
                            >
                              {{ block.settings[accordion_title_key] }}
                              <span class="ctm-accordion-icon-{{ ctm_gen_id }}">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="14" viewBox="0 0 13 14" fill="none">
                                  <path d="M5.60495 13.7237V7.77287H0.296875V6.19997H5.60495V0.275391H7.09224V6.19997H12.4003V7.77287H7.09224V13.7237H5.60495Z" fill="#2E2E24"></path>
                                </svg>
                              </span>
                            </button>
                            <div class="ctm-accordion-content-{{ ctm_gen_id }}">
                              <div class="ctm-accordion-body-{{ ctm_gen_id }}">
                                {{ block.settings[accordion_content_key] }}
                              </div>
                            </div>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ctm-tab-contents-{{ ctm_gen_id }}">
      {% for i in (1..5) %}
        {% assign tab_enabled_key = 'tab_' | append: i | append: '_enabled' %}
        {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
        {% assign tab_image_key = 'tab_' | append: i | append: '_image' %}
        {% assign tab_content_title_key = 'tab_' | append: i | append: '_content_title' %}
        {% assign tab_description_key = 'tab_' | append: i | append: '_description' %}
        
        {% if block.settings[tab_enabled_key] and block.settings[tab_title_key] != blank %}
          <div class="ctm-tab-content-{{ ctm_gen_id }} {% if forloop.first %}active{% endif %}" data-tab-content="tab-{{ i }}">
            <div class="ctm-content-wrapper-{{ ctm_gen_id }} {% if block.settings.image_position == 'right' %}image-right{% endif %}">
              <div class="ctm-image-container-{{ ctm_gen_id }}">
                {% if block.settings[tab_image_key] %}
                  <img
                    src="{{ block.settings[tab_image_key] | image_url: width: 800 }}"
                    alt="{{ block.settings[tab_image_key].alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings[tab_image_key].width }}"
                    height="{{ block.settings[tab_image_key].height }}"
                  >
                {% else %}
                  <div class="ctm-image-placeholder-{{ ctm_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ctm-text-container-{{ ctm_gen_id }}">
                <div class="ctm-product-tabs_inner">
                  {% if block.settings[tab_content_title_key] != blank %}
                    <h3 class="ctm-tab-title-{{ ctm_gen_id }}">{{ block.settings[tab_content_title_key] }}</h3>
                  {% endif %}

                  {% if block.settings[tab_description_key] != blank %}
                    <div class="ctm-tab-description-{{ ctm_gen_id }}">
                      {{ block.settings[tab_description_key] }}
                    </div>
                  {% endif %}
                </div>
                <div class="ctm-accordion-{{ ctm_gen_id }}">
                  {% for j in (1..3) %}
                    {% assign accordion_enabled_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_enabled' %}
                    {% assign accordion_title_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_title' %}
                    {% assign accordion_content_key = 'tab_' | append: i | append: '_accordion_' | append: j | append: '_content' %}
                    
                    {% if block.settings[accordion_enabled_key] and block.settings[accordion_title_key] != blank %}
                      <div class="ctm-accordion-item-{{ ctm_gen_id }}">
                        <button
                          class="ctm-accordion-header-{{ ctm_gen_id }}"
                          aria-expanded="false"
                          data-accordion="tab-{{ i }}-acc-{{ j }}"
                        >
                          {{ block.settings[accordion_title_key] }}
                          <span class="ctm-accordion-icon-{{ ctm_gen_id }}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="14" viewBox="0 0 13 14" fill="none">
                              <path d="M5.60495 13.7237V7.77287H0.296875V6.19997H5.60495V0.275391H7.09224V6.19997H12.4003V7.77287H7.09224V13.7237H5.60495Z" fill="#2E2E24"></path>
                            </svg>
                          </span>
                        </button>
                        <div class="ctm-accordion-content-{{ ctm_gen_id }}">
                          <div class="ctm-accordion-body-{{ ctm_gen_id }}">
                            {{ block.settings[accordion_content_key] }}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</product-tabs-{{ ctm_gen_id }}>

{% style %}
  .ctm-product-tabs-{{ ctm_gen_id }} {
    display: block;
    width: 100%;
    padding: 55px 0px;
  }
  .ctm-tab-buttons-{{ ctm_gen_id }} {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ctm-tab-button-{{ ctm_gen_id }} {
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    background-color:#e9f0ff;
    color:#000F3C;
    transition: all 0.3s ease;
    flex: 1;
    font-weight: 600;
    border-radius: 12px;
    text-transform: capitalize;
  }

  .ctm-tab-button-{{ ctm_gen_id }}:hover {
    background-color: #000F3C;
    color: #e9f0ff;
  }

  .ctm-tab-button-{{ ctm_gen_id }}.active {
    background-color: #000F3C;
    color: #e9f0ff;
  }

  .ctm-tab-content-{{ ctm_gen_id }} {
    display: none;
  }

  .ctm-tab-content-{{ ctm_gen_id }}.active {
    display: block;
  }

  .ctm-content-wrapper-{{ ctm_gen_id }} {
    display: flex;
    gap: 32px;
    padding:20px;
    background-color:#e9f0ff;
    border-radius: 12px;
  }

  .ctm-content-wrapper-{{ ctm_gen_id }}.image-right {
    flex-direction: row-reverse;
  }

  .ctm-image-container-{{ ctm_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
  }

  .ctm-image-container-{{ ctm_gen_id }} img {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ctm-image-placeholder-{{ ctm_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ctm-image-placeholder-{{ ctm_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ctm-text-container-{{ ctm_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap:20px;
  }
  .ctm-product-tabs_inner {
      flex: 1;
  }
  .ctm-tab-title-{{ ctm_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ctm-tab-description-{{ ctm_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .ctm-accordion-{{ ctm_gen_id }} {
    border-top: 1px solid {{ block.settings.accordion_border_color }};
  }

  .ctm-accordion-item-{{ ctm_gen_id }} {
    border-bottom: 1px solid {{ block.settings.accordion_border_color }};
  }

  .ctm-accordion-header-{{ ctm_gen_id }} {
    width: 100%;
    padding: 16px 0;
    background: none;
    border: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: {{ block.settings.accordion_font_size }}px;
    color: {{ block.settings.accordion_text_color }};
    font-weight: 600;
    text-align: left;
  }

  .ctm-accordion-icon-{{ ctm_gen_id }} {
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 12px;
  }

  .ctm-accordion-header-{{ ctm_gen_id }}[aria-expanded="true"] .ctm-accordion-icon-{{ ctm_gen_id }} {
    transform: rotate(45deg);
  }

  .ctm-accordion-content-{{ ctm_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ctm-accordion-content-{{ ctm_gen_id }}.active {
    max-height: 1000px;
  }

  .ctm-accordion-body-{{ ctm_gen_id }} {
    padding: 0 0 16px 0;
    font-size: {{ block.settings.accordion_content_font_size }}px;
    color: {{ block.settings.accordion_content_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 767px) {
    .ctm-tab-buttons-{{ ctm_gen_id }} {
      display: none;
    }

    .ctm-content-wrapper-{{ ctm_gen_id }} {
      flex-direction: column;
      gap: 20px;
    }

    .ctm-image-container-{{ ctm_gen_id }} {
      flex: 0 0 100%;
    }

    .ctm-mobile-accordion-{{ ctm_gen_id }} {
      display: block;
    }

    .ctm-mobile-accordion-item-{{ ctm_gen_id }} {
      border-bottom: 1px solid {{ block.settings.accordion_border_color }};
    }

    .ctm-mobile-accordion-header-{{ ctm_gen_id }} {
      width: 100%;
      padding: 16px 0;
      background: none;
      border: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: {{ block.settings.tab_font_size }}px;
      color: {{ block.settings.tab_text_color }};
      font-weight: 600;
      text-align: left;
    }

    .ctm-mobile-accordion-icon-{{ ctm_gen_id }} {
      transition: transform 0.3s ease;
      flex-shrink: 0;
      margin-left: 12px;
    }

    .ctm-mobile-accordion-header-{{ ctm_gen_id }}[aria-expanded="true"] {
      color: {{ block.settings.tab_active_color }};
    }

    .ctm-mobile-accordion-header-{{ ctm_gen_id }}[aria-expanded="true"] .ctm-mobile-accordion-icon-{{ ctm_gen_id }} {
      transform: rotate(180deg);
    }

    .ctm-mobile-accordion-content-{{ ctm_gen_id }} {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .ctm-mobile-accordion-content-{{ ctm_gen_id }}.active {
      max-height: 3000px;
    }

    .ctm-mobile-accordion-body-{{ ctm_gen_id }} {
      padding: 0 0 16px 0;
    }

    .ctm-tab-title-{{ ctm_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ctm-tab-description-{{ ctm_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }
  }

  @media screen and (min-width: 768px) {
    .ctm-mobile-accordion-{{ ctm_gen_id }} {
      display: none;
    }
  }
  @media screen and (max-width: 767px) {
    .ctm-tab-contents-{{ ctm_gen_id }} {
      display: none;
    }
    .ctm-text-container-{{ ctm_gen_id }} {
      gap: 0px;
    }
    .ctm-tab-description-{{ ctm_gen_id }} {
      margin-bottom: 0px;
    }
    .ctm-tab-description-{{ ctm_gen_id }} p {
      margin-top:0px;
    }
    .ctm-mobile-accordion-header-{{ ctm_gen_id }} {
      padding:16px;
    }
    .ctm-mobile-accordion-header-{{ ctm_gen_id }}[aria-expanded="true"] {
      background-color: #e9f0ff;
      border-radius: 12px 12px 0px 0px;
    }
    .ctm-mobile-accordion-content-{{ ctm_gen_id }} .ctm-content-wrapper-{{ ctm_gen_id }} {
      border-radius: 0px 0px 12px 12px;
      padding-top: 0px;
    }
    .ctm-mobile-accordion-icon-{{ ctm_gen_id }} svg g > path {
      fill: #043085;
    }
    .ctm-mobile-accordion-icon-{{ ctm_gen_id }} svg g ~ path {
      fill: #fff;
    }
    .ctm-accordion-body-{{ ctm_gen_id }} p {
      margin:0px;
    }
  }
{% endstyle %}

<script>
  (function() {
    class ProductTabs{{ ctm_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabButtons = this.querySelectorAll('.ctm-tab-button-{{ ctm_gen_id }}');
        this.tabContents = this.querySelectorAll('.ctm-tab-content-{{ ctm_gen_id }}');
        this.accordionHeaders = this.querySelectorAll('.ctm-accordion-header-{{ ctm_gen_id }}');
        this.mobileAccordionHeaders = this.querySelectorAll('.ctm-mobile-accordion-header-{{ ctm_gen_id }}');
        
        this.setupTabListeners();
        this.setupAccordionListeners();
        this.setupMobileAccordionListeners();
      }

      setupTabListeners() {
        this.tabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetTab = button.getAttribute('data-tab');
            
            this.tabButtons.forEach((btn) => {
              btn.classList.remove('active');
              btn.setAttribute('aria-selected', 'false');
            });
            
            this.tabContents.forEach((content) => {
              content.classList.remove('active');
            });
            
            button.classList.add('active');
            button.setAttribute('aria-selected', 'true');
            
            const targetContent = this.querySelector(`[data-tab-content="${targetTab}"]`);
            if (targetContent) {
              targetContent.classList.add('active');
            }
          });
        });
      }

      setupAccordionListeners() {
        this.accordionHeaders.forEach((header) => {
          header.addEventListener('click', () => {
            const isExpanded = header.getAttribute('aria-expanded') === 'true';
            const content = header.nextElementSibling;
            const parentTab = header.closest('.ctm-mobile-accordion-body-{{ ctm_gen_id }}');
            
            if (parentTab) {
              const allAccordionsInTab = parentTab.querySelectorAll('.ctm-accordion-header-{{ ctm_gen_id }}');
              allAccordionsInTab.forEach((h) => {
                if (h !== header) {
                  h.setAttribute('aria-expanded', 'false');
                  h.nextElementSibling.classList.remove('active');
                }
              });
            } else {
              const parentContent = header.closest('.ctm-tab-content-{{ ctm_gen_id }}');
              if (parentContent) {
                const allAccordionsInTab = parentContent.querySelectorAll('.ctm-accordion-header-{{ ctm_gen_id }}');
                allAccordionsInTab.forEach((h) => {
                  if (h !== header) {
                    h.setAttribute('aria-expanded', 'false');
                    h.nextElementSibling.classList.remove('active');
                  }
                });
              }
            }
            
            header.setAttribute('aria-expanded', !isExpanded);
            
            if (!isExpanded) {
              content.classList.add('active');
            } else {
              content.classList.remove('active');
            }
          });
        });
      }

      setupMobileAccordionListeners() {
        this.mobileAccordionHeaders.forEach((header) => {
          header.addEventListener('click', () => {
            const isExpanded = header.getAttribute('aria-expanded') === 'true';
            const content = header.nextElementSibling;
            
            this.mobileAccordionHeaders.forEach((h) => {
              if (h !== header) {
                h.setAttribute('aria-expanded', 'false');
                h.nextElementSibling.classList.remove('active');
              }
            });
            
            header.setAttribute('aria-expanded', !isExpanded);
            
            if (!isExpanded) {
              content.classList.add('active');
            } else {
              content.classList.remove('active');
            }
          });
        });
      }
    }

    customElements.define('product-tabs-{{ ctm_gen_id }}', ProductTabs{{ ctm_gen_id }});
  })();
</script>

