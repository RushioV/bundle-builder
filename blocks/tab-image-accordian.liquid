
{% assign ctm_gen_id = block.id | replace: '_', '' | downcase %}



<product-tabs-{{ ctm_gen_id }} class="ctm-product-tabs-{{ ctm_gen_id }}" {{ block.shopify_attributes }}>
  <div class="page-width ctm-tabs-container-{{ ctm_gen_id }}">
    <div class="ctm-tab-buttons-{{ ctm_gen_id }}">
      {% for i in (1..5) %}
        {% assign tab_enabled_key = 'tab_' | append: i | append: '_enabled' %}
        {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
        {% if block.settings[tab_enabled_key] and block.settings[tab_title_key] != blank %}
          <button
            class="ctm-tab-button-{{ ctm_gen_id }} {% if forloop.first %}active{% endif %}"
            data-tab="tab-{{ i }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          >
            {{ block.settings[tab_title_key] }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ctm-mobile-accordion-{{ ctm_gen_id }}">
      {% for i in (1..5) %}
        {% assign tab_enabled_key = 'tab_' | append: i | append: '_enabled' %}
        {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
        {% assign tab_image_key = 'tab_' | append: i | append: '_image' %}
        {% assign tab_content_title_key = 'tab_' | append: i | append: '_content_title' %}
        {% assign tab_description_key = 'tab_' | append: i | append: '_description' %}
        
        {% if block.settings[tab_enabled_key] and block.settings[tab_title_key] != blank %}
          <div class="ctm-mobile-accordion-item-{{ ctm_gen_id }}">
            <button
              class="ctm-mobile-accordion-header-{{ ctm_gen_id }}"
              aria-expanded="false"
              data-mobile-tab="{{ i }}"
            >
              {{ block.settings[tab_title_key] }}
              <span class="ctm-mobile-accordion-icon-{{ ctm_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="29" height="29" viewBox="0 0 29 29" fill="none">
                  <g clip-path="url(#clip0_204_38896)">
                    <path d="M27.3929 11.9692C27.2322 11.8086 26.9912 11.6479 26.9912 11.4069C26.9912 11.2462 27.0716 11.1659 27.1519 11.0052C27.7142 10.0413 27.4732 8.6756 26.5092 8.03294C25.8666 7.63128 25.0632 7.55095 24.3403 7.71161C23.6173 7.87228 22.9746 8.19361 22.3319 8.59527C21.7696 8.99693 21.127 9.31826 20.5646 9.80026C20.5646 9.47893 20.5646 9.1576 20.3236 8.9166C20.4843 8.75594 20.645 8.59527 20.8056 8.51494C21.7696 7.63128 22.7336 6.66729 23.2959 5.46231C23.5369 4.81965 23.6976 4.09666 23.3763 3.454C22.8943 2.49001 21.5286 2.40967 20.4843 2.65067C20.2433 2.731 20.0023 2.731 19.8416 2.57034C19.7613 2.49001 19.681 2.32934 19.681 2.24901C19.2793 1.20469 18.0743 0.56203 16.9497 0.883359C16.2267 1.12436 15.6644 1.68668 15.343 2.32934C15.0217 2.972 14.861 3.77533 14.7807 4.49832C14.7004 4.89998 14.7004 5.22131 14.7004 5.62297C14.4594 5.46231 14.138 5.38197 13.897 5.46231H13.8167C13.7364 4.17699 13.5757 2.89167 12.9331 1.76702C12.6117 1.12436 12.1297 0.56203 11.4067 0.481697C10.3624 0.2407 9.39842 1.20469 8.99676 2.24901C8.91643 2.40967 8.8361 2.65067 8.5951 2.731C8.43443 2.731 8.3541 2.731 8.19344 2.65067C7.14912 2.24901 5.8638 2.89167 5.46214 3.93599C5.22114 4.57865 5.30147 5.38197 5.6228 6.02463C5.94413 6.66729 6.42612 7.22962 6.90812 7.79195C7.63111 8.59527 8.43443 9.31826 9.31809 9.96092C9.31809 9.96092 9.31809 9.96092 9.39842 10.0413C8.99676 9.88059 8.5951 9.88059 8.19344 10.0413C7.87211 9.80026 7.55078 9.55926 7.22945 9.31826C6.10479 8.59527 4.98014 7.87228 3.69482 7.63128C2.97183 7.47062 2.16851 7.47062 1.68651 7.95261C0.883187 8.6756 1.04385 9.96092 1.52585 10.9249C1.60618 11.1659 1.68651 11.4069 1.60618 11.6479C1.52585 11.7282 1.44551 11.8086 1.28485 11.8889C0.32086 12.4512 -0.000470132 13.8972 0.561857 14.8612C0.963519 15.5039 1.60618 15.9055 2.32917 16.0662C3.05216 16.2268 3.77515 16.2268 4.57848 16.1465C5.22114 16.0662 5.78346 15.9859 6.42612 15.8252V15.9055C6.42612 16.1465 6.58679 16.3875 6.66712 16.6285C6.42612 16.7088 6.10479 16.7892 5.8638 16